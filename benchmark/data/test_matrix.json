{
  "version": "2.0",
  "description": "CrossCell 性能基准测试矩阵 — 全量数据集覆盖",
  "tools": [
    {
      "name": "crosscell",
      "type": "cli",
      "supports_v5": true,
      "directions": ["rds_to_h5ad", "h5ad_to_rds"]
    },
    {
      "name": "zellkonverter",
      "type": "r",
      "supports_v5": true,
      "directions": ["rds_to_h5ad", "h5ad_to_rds"]
    },
    {
      "name": "anndataR",
      "type": "r",
      "supports_v5": true,
      "directions": ["rds_to_h5ad", "h5ad_to_rds"]
    },
    {
      "name": "convert2anndata",
      "type": "r",
      "supports_v5": false,
      "directions": ["rds_to_h5ad"]
    },
    {
      "name": "easySCF",
      "type": "r",
      "supports_v5": true,
      "directions": ["rds_to_h5ad"],
      "note": "输出为 easySCF 自有 H5 格式，非标准 H5AD；h5ad_to_rds 不可用（Python/R 编码不兼容）"
    }
  ],
  "directions": {
    "rds_to_h5ad": {
      "description": "Seurat RDS → AnnData H5AD",
      "input_format": "rds",
      "output_format": "h5ad"
    },
    "h5ad_to_rds": {
      "description": "AnnData H5AD → Seurat RDS",
      "input_format": "h5ad",
      "output_format": "rds"
    }
  },
